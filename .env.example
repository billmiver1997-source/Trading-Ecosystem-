# Trading Nova — environment template.
# Copy to .env, fill in real values, and NEVER commit the filled-in .env file.
#
# Telegram bot tokens — 3 separate bot identities, from @BotFather
TELEGRAM_TOKEN_SIGNAL=
TELEGRAM_TOKEN_MAIN=
TELEGRAM_TOKEN_NEWS=

# Telegram channel IDs the bots post to (numeric, e.g. -1001234567890)
SIGNALS_CHANNEL=
TELEGRAM_NEWS_CHANNEL=
TELEGRAM_UPDATES_CHANNEL=

# Your own Telegram user ID — gets admin-only commands (/stats) and monitor.sh DOWN/RESTARTED alerts
OWNER_ID=
ADMIN_CHAT_ID=

# AI provider — https://console.anthropic.com (Plans & Billing must have credit)
ANTHROPIC_API_KEY=

# Optional — used by earnings_bot.py for stock data; features degrade gracefully if unset
ALPHA_VANTAGE_KEY=

# Optional — override where chart.py writes generated PNGs (defaults to /root/tradingbot/charts)
CHARTS_DIR=
